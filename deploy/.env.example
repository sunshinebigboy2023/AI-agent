FRONTEND_PORT=5021
DASHSCOPE_API_KEY=replace-with-your-dashscope-api-key
SPRING_AI_DASHSCOPE_CHAT_OPTIONS_MODEL=qwen-plus
SEARXNG_PORT=8080
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_PUBLIC_BASE_URL=http://localhost:8080/
SEARXNG_TOP_K=5
ALIYUN_OPENSEARCH_HOST=https://your-region.opensearch.aliyuncs.com
ALIYUN_OPENSEARCH_API_KEY=replace-with-your-opensearch-api-key
ALIYUN_OPENSEARCH_WORKSPACE=default
ALIYUN_OPENSEARCH_SERVICE_ID=ops-web-search-001
ALIYUN_OPENSEARCH_TOP_K=5
ALIYUN_OPENSEARCH_CONTENT_TYPE=snippet
OFFICE_ALLOWED_ORIGINS=*
OFFICE_ENABLE_TERMINAL_TOOL=false
OFFICE_AGENT_MAX_STEPS=20
OFFICE_AGENT_MAX_OBSERVATION_LENGTH=4000
OFFICE_CHAT_MAX_MESSAGE_LENGTH=8000
OFFICE_KNOWLEDGE_DIR=/app/tmp/knowledge
OFFICE_KNOWLEDGE_MAX_UPLOAD_BYTES=10485760
OFFICE_KNOWLEDGE_CHUNK_SIZE=1000
OFFICE_KNOWLEDGE_CHUNK_OVERLAP=150
OFFICE_KNOWLEDGE_REBUILD_ON_STARTUP=true
OFFICE_TOOLS_WORKSPACE_DIR=/app/tmp/workspace
OFFICE_DOWNLOAD_MAX_BYTES=10485760
OFFICE_WEB_SCRAPING_TIMEOUT_MS=10000
OFFICE_WEB_SCRAPING_MAX_BODY_SIZE=200000
